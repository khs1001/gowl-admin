{
    "type": "input-text",
    "name": "key",
    "label": "键",
    "required": true,
    "maxLength": 255,
    "addOn": {
        "type": "button",
        "label": "随机",
        "icon": "fa-solid fa-shuffle",
        "onEvent": {
            "click": {
                "actions": [
                    {
                        "actionType": "setValue",
                        "componentId": "dict_item_form",
                        "args": {
                            "value": {
                                "key": "${PADSTART(INT(RAND()*1000000000), 9, \"0\") | base64Encode | lowerCase}"
                            }
                        }
                    }
                ]
            }
        }
    }
}