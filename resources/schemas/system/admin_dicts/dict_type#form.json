{
    "type": "input-tree",
    "name": "dict_type",
    "id": "dict_type_list",
    "source": "get:{{.Path}}/dict_type_options",
    "valueField": "id",
    "labelField": "value",
    "showIcon": false,
    "searchable": false,
    "rootCreateTip": "新增字典类型",
    "selectFirst": true,
    "creatable": true,
    "addControls": [
        {
            "type": "input-text",
            "name": "value",
            "label": "类型名称",
            "required": true,
            "maxLength": 255
        },
        {
            "type": "input-text",
            "name": "key",
            "label": "类型标识",
            "required": true,
            "maxLength": 255
        },
        {
            "type": "switch",
            "name": "enabled",
            "label": "是否启用",
            "value": 1
        }
    ],
    "editable": true,
    "editControls": [
        {
            "type": "input-text",
            "name": "value",
            "label": "类型名称",
            "required": true,
            "maxLength": 255
        },
        {
            "type": "input-text",
            "name": "key",
            "label": "类型标识",
            "required": true,
            "maxLength": 255
        },
        {
            "type": "switch",
            "name": "enabled",
            "label": "是否启用",
            "value": 1
        },
        {
            "type": "hidden",
            "name": "id"
        }
    ],
    "removable": true,
    "addApi": "post:{{.Path}}",
    "editApi": "put:{{.Path}}/${id}",
    "deleteApi": "delete:{{.Path}}/${id}",
    "menuTpl": "<span class=\"${!enabled ? \"text-gray-300\" : \"\"} w-1/5\">${value}</div>",
    "onEvent": {
        "change": {
            "actions": [
                {
                    "actionType": "url",
                    "args": {
                        "url": "{{.Path}}?dict_type=${dict_type}"
                    }
                }
            ]
        }
    }
}