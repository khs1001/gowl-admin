{
    "type": "input-tree",
    "name": "dict_type",
    "id": "dict_type_list",
    "source": "get:{{.Path}}?type=dict_type",
    "valueField": "value",
    "labelField": "label",
    "showIcon": false,
    "searchable": false,
    "rootCreateTip": "新增字典类型",
    "selectFirst": true,
    "creatable": true,
    "addControls": [
        {
            "type": "hidden",
            "name": "type",
            "value": "dict_type"
         },
        "@value#form",
        "@label#form",
        "@enabled#form"
    ],
    "editable": true,
    "editControls": [
        "@value#form",
        "@label#form",
        "@enabled#form",
        {
            "type": "hidden",
            "name": "id"
        }
    ],
    "removable": true,
    "addApi": "post:{{.Path}}",
    "editApi": "put:{{.Path}}/${id}",
    "deleteApi": "delete:{{.Path}}/${id}",
    "menuTpl": "<span class=\"${!enabled ? \"text-gray-300\" : \"\"} w-1/5\">${label}</div>",
    "onEvent": {
        "change": {
            "actions": [
                {
                    "actionType": "url",
                    "args": {
                        "url": "{{.Path}}?type=${dict_type}"
                    }
                }
            ]
        }
    }
}