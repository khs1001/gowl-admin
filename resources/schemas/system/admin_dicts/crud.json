{
    "type": "@crud",
    "api": {
		"url": "{{.Path}}?_action=getData&type=${type}&orderBy=sort&orderDir=asc",
		"method": "get"
	},
    "columns":[
        "@id#column",
        "@value#column",
        "@label#column",
        "@is_enable#column",
        "@sort#column",
        "@created_at#column"
    ],
    "footerToolbar":[],
    "syncLocation": true,
	"quickSaveItemApi": {
		"url": "{{.Path}}/${id}",
		"method": "put",
		"data": {
			"is_enable":"${is_enable}",
            "sort":"${sort}"
		}
	}
}